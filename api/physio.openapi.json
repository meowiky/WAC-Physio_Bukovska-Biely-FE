      "RehabilitationSession": {
        "type": "object",
        "required": [
          "id",
          "planId",
          "ambulanceId",
          "therapistId",
          "attendanceStatus",
          "confirmationStatus"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "session-001",
            "description": "Unique identifier of the session"
          },
          "planId": {
            "type": "string",
            "example": "plan-001",
            "description": "Identifier of the parent rehabilitation plan"
          },
          "ambulanceId": {
            "type": "string",
            "example": "ambulance-a12",
            "description": "Identifier of the ambulance or room where the session takes place"
          },
          "therapistId": {
            "type": "string",
            "example": "therapist-001",
            "description": "Identifier of the doctor or physiotherapist assigned to the session"
          },
          "startDateTime": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2026-05-05T08:30:00Z",
            "description": "Start of the session. May be null for tentative scheduling."
          },
          "endDateTime": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2026-05-05T09:15:00Z",
            "description": "End of the session. May be null for tentative scheduling."
          },
