{
  "openapi": "3.0.0",
  "info": {
    "title": "Physio API",
    "version": "1.0.0",
    "description": "Physio rehabilitation management API for Web-In-Cloud system",
    "contact": {
      "email": "xbukovska@stuba.sk"
    },
    "license": {
      "name": "CC BY 4.0",
      "url": "https://creativecommons.org/licenses/by/4.0/"
    }
  },
  "servers": [
    {
      "description": "Cluster Endpoint",
      "url": "/api"
    }
  ],
  "tags": [
    {
      "name": "patients",
      "description": "Patient registry managed by receptionist or physiotherapist"
    },
    {
      "name": "therapists",
      "description": "Doctors and physiotherapists who can lead rehabilitation sessions"
    },
    {
      "name": "ambulances",
      "description": "Ambulances and rooms where rehabilitation sessions take place"
    },
    {
      "name": "rehabilitationPlans",
      "description": "Rehabilitation plans assigned to one patient"
    },
    {
      "name": "rehabilitationSessions",
      "description": "Sessions belonging to a rehabilitation plan"
    },
    {
      "name": "availability",
      "description": "Availability checks for ambulances and therapists"
    }
  ],
  "paths": {
    "/patients": {
      "get": {
        "tags": [
          "patients"
        ],
        "summary": "List patients",
        "operationId": "getPatients",
        "description": "Returns registered patients.",
        "responses": {
          "200": {
            "description": "List of patients",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Patient"
                  }
                },
                "examples": {
                  "response": {
                    "$ref": "#/components/examples/PatientsExample"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "patients"
        ],
        "summary": "Create patient",
        "operationId": "createPatient",
        "description": "Creates a new patient.",
        "requestBody": {
          "description": "Patient data to store",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Patient"
              },
              "examples": {
                "request": {
                  "$ref": "#/components/examples/PatientExample"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Stored patient",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Patient"
                },
                "examples": {
                  "response": {
                    "$ref": "#/components/examples/PatientExample"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "409": {
            "description": "Patient with the specified id or birth number already exists"
          }
        }
      }
    },
    "/patients/{patientId}": {
      "parameters": [
        {
          "in": "path",
          "name": "patientId",
