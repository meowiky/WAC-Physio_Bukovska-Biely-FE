          "confirmationStatus": {
            "$ref": "#/components/schemas/SessionConfirmationStatus"
          },
          "sessionNotes": {
            "type": "string",
            "example": "Session reserved, exact time will be confirmed after phone call with patient."
          }
        }
      },
      "AttendanceStatus": {
        "type": "string",
        "enum": [
          "planned",
          "attended",
          "canceled"
        ],
        "example": "planned"
      },
      "SessionConfirmationStatus": {
        "type": "string",
        "enum": [
          "tentative",
          "confirmed"
        ],
        "example": "tentative"
      },
      "AvailabilityResult": {
        "type": "object",
        "required": [
          "startDateTime",
          "endDateTime"
        ],
        "properties": {
          "startDateTime": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-05T08:30:00Z"
          },
          "endDateTime": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-05T09:15:00Z"
          },
          "ambulance": {
            "$ref": "#/components/schemas/AvailabilityCheckItem"
          },
