          "id",
          "firstName",
          "surname",
          "birthNumber",
          "dateOfBirth",
          "sex",
          "healthInsurance",
          "email",
          "phone",
          "firstVisitDate"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "patient-001",
            "description": "Unique identifier of the patient"
          },
          "firstName": {
            "type": "string",
            "example": "Janko"
          },
          "surname": {
            "type": "string",
            "example": "Mrkvicka"
          },
          "birthNumber": {
            "type": "string",
