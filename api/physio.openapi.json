          "409": {
            "description": "Selected therapist or ambulance is not available for the requested time interval"
          }
        }
      },
      "delete": {
        "tags": [
          "rehabilitationSessions"
        ],
        "summary": "Delete rehabilitation session",
        "operationId": "deleteRehabilitationSession",
        "description": "Deletes a rehabilitation session.",
        "responses": {
          "204": {
            "description": "Rehabilitation session deleted"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/availability": {
      "get": {
        "tags": [
          "availability"
        ],
        "summary": "Check ambulance and therapist availability",
        "operationId": "checkAvailability",
        "description": "Checks whether the selected ambulance is free and whether the selected therapist has no overlapping session in the requested time interval.",
        "parameters": [
          {
            "in": "query",
            "name": "startDateTime",
            "description": "Requested session start date and time.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "in": "query",
            "name": "endDateTime",
            "description": "Requested session end date and time.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "in": "query",
            "name": "ambulanceId",
            "description": "Optional ambulance to check.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "therapistId",
            "description": "Optional therapist to check.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "excludeSessionId",
            "description": "Optional session id to ignore during overlap checks, useful while editing an existing session.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Availability result for the requested interval",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AvailabilityResult"
                },
                "examples": {
                  "response": {
                    "$ref": "#/components/examples/AvailabilityResultExample"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "description": "Specified therapist or ambulance does not exist"
          }
        }
      }
    }
  },
  "components": {
    "responses": {
      "BadRequest": {
        "description": "Missing mandatory properties or invalid values in the request body."
      },
      "NotFound": {
        "description": "Requested resource does not exist."
      },
      "PathBodyIdMismatch": {
        "description": "Identifier in path does not match identifier in the request body."
      }
    },
    "schemas": {
      "Patient": {
        "type": "object",
