{
  "name": "wac-physio-ufe",
  "version": "0.0.1",
  "description": "Physio rehabilitation management microfrontend",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/wac-physio-ufe/wac-physio-ufe.esm.js",
  "exports": {
    ".": {
      "import": "./dist/wac-physio-ufe/wac-physio-ufe.esm.js",
      "require": "./dist/wac-physio-ufe/wac-physio-ufe.cjs.js"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs",
      "types": "./loader/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build",
    "openapi": "openapi-generator-cli generate",
    "start:app": "stencil build --dev --watch --serve",
    "start": "npm run start:app",
    "test": "stencil test --spec --e2e",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "test:jest": "jest --config ./jest.config.js",
    "generate": "stencil generate"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@stencil/core": "4.27.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "puppeteer": "^24.3.0"
  },
  "license": "MIT",
  "dependencies": {
    "@material/web": "^2.4.1"
  }
}
